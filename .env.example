# ── Site ──────────────────────────────────────────────────────────
# Public base URL of the deployed site (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://printprofitsystem.fr

# Calendly link used by every "Demander un rappel" / "Choisir un
# créneau" CTA. Override only if this link ever changes.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/printprofitsystem/appel-de-decouverte-print-profit-system

# ── Contact form: email delivery (SMTP / Nodemailer) ────────────────
# If SMTP_HOST/SMTP_USER/SMTP_PASS are left empty, the form still works
# (validation + webhook, if configured) but email sending is skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Recipient of contact form emails. Defaults to SMTP_USER if unset.
CONTACT_EMAIL_TO=contact@printprofitsystem.fr
# "From" address used when sending. Defaults to SMTP_USER if unset.
CONTACT_EMAIL_FROM=

# ── Contact form: webhook (Make / n8n) ──────────────────────────────
# Leave empty to skip webhook forwarding until you have a real URL.
WEBHOOK_URL=

# ── Audit de faisabilité : Supabase (base de données + auth) ────────
# Créez un projet sur https://supabase.com, exécutez
# supabase/migrations/0001_init_audit_schema.sql dans l'éditeur SQL,
# puis renseignez ces 3 valeurs depuis Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé secrète — jamais exposée au client, utilisée uniquement dans les
# routes serveur (création d'invitations, etc.). Ne jamais préfixer par
# NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
